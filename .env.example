# ─────────────────────────────────────────────────────────────────────────────
# Production .env for EC2 deployment
# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── CORS ─────────────────────────────────────────────────────────────────────
# Replace with your EC2 public IP or domain (comma-separated for multiple).
# Since nginx proxies /api/ internally, the browser origin is your public host.
# Example: http://54.123.45.67   or   https://app.example.com
ALLOWED_ORIGINS=http://<EC2_PUBLIC_IP_OR_DOMAIN>

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SIGNED_URL_SECRET=change-me-to-a-random-64-char-hex-string

# ── MongoDB (uses internal Docker network name by default) ────────────────────
# Only change if you use an external Atlas cluster or RDS DocumentDB endpoint.
# MONGO_URI=mongodb://mongo:27017
# MONGO_DB=data_quality

